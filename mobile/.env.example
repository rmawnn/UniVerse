# ── API ──────────────────────────────────────────────────────
# Production: set to your deployed backend URL.
# Local dev:  leave empty — auto-detects emulator/simulator localhost.
#
# Examples:
#   Development: (leave empty or omit)
#   Staging:     https://universe-staging.onrender.com/api/v1
#   Production:  https://universe-api.onrender.com/api/v1
EXPO_PUBLIC_API_URL=

# ── Local Development Only ───────────────────────────────────
# Set this to your machine's LAN IP when testing on a physical device.
# Run `ipconfig` (Windows) or `ifconfig` (Mac) to find it.
# Not needed for emulators/simulators — they auto-route to localhost.
# EXPO_PUBLIC_DEV_IP=192.168.1.100
