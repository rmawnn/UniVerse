# ── Application ──────────────────────────────────────────────
APP_NAME=UniVerse
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
DEBUG=True
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────
# Set each field individually — the app builds the connection URL
# automatically with proper encoding. No need to URL-encode your password.
#
# DB_PASSWORD is the password you set when installing PostgreSQL.
#
# To verify your credentials work:
#   psql -U postgres -h localhost -d universe_db
#
# If the database doesn't exist yet:
#   psql -U postgres -h localhost -c "CREATE DATABASE universe_db;"
#
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_HOST=localhost
DB_PORT=5432
DB_NAME=universe_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── JWT / Auth ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# JSON array or comma-separated string
CORS_ORIGINS=["http://localhost:3000"]
