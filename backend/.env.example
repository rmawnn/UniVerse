# ── Application ──────────────────────────────────────────────
APP_NAME=UniVerse
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
DEBUG=True
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────
# Two options — pick ONE:
#
# ╔══ Option A: Full DATABASE_URL (recommended for Supabase) ══╗
# ║  Copy the connection string from Supabase → Project Settings        ║
# ║  → Database → Connection string → URI.                              ║
# ║  Any prefix (postgres://, postgresql://) is auto-normalised.        ║
# ║  sslmode=require in the URL is detected automatically.              ║
# ╚═════════════════════════════════════════════════════════════╝
#
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# ╔══ Option B: Individual fields (used when DATABASE_URL is empty) ══╗
# ║  LOCAL:   DB_HOST=localhost  DB_PASSWORD=<local pg password>        ║
# ║  DOCKER:  DB_HOST is overridden to "postgres" by docker-compose.    ║
# ║  SUPABASE: DB_HOST=db.<ref>.supabase.co DB_NAME=postgres            ║
# ╚═════════════════════════════════════════════════════════════════════╝
#
DATABASE_URL=
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=universe_db
DB_SSLMODE=             # "require" for Supabase; leave empty for auto-detect
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── Supabase ─────────────────────────────────────────────────
# Required for Storage (file uploads) and Realtime (chat, presence).
# Get these from your Supabase project → Settings → API.
# Leave empty to use local filesystem + in-memory WebSocket instead.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket names (defaults are fine for most setups)
# SUPABASE_BUCKET_AVATARS=avatars
# SUPABASE_BUCKET_POSTS=posts
# SUPABASE_BUCKET_VERIFICATION=verification-docs
# SUPABASE_BUCKET_ATTACHMENTS=attachments
# SUPABASE_BUCKET_RESUMES=resumes

# ── JWT / Auth ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# JSON array or comma-separated string
# Include Expo web dev server ports (19006, 8081) for mobile dev
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006","http://localhost:8081"]
