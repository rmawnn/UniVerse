# ── Application ──────────────────────────────────────────────
APP_NAME=UniVerse
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
DEBUG=True
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────
# Set each field individually — the app builds the connection URL
# automatically with proper encoding. No need to URL-encode your password.
#
# LOCAL (without Docker):
#   DB_HOST=localhost
#   DB_PASSWORD=<your local postgres password>
#
# DOCKER (docker-compose):
#   DB_HOST is overridden to "postgres" by docker-compose.yml.
#   DB_PASSWORD just needs to match POSTGRES_PASSWORD (defaults to "postgres").
#
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=universe_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── JWT / Auth ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# JSON array or comma-separated string
CORS_ORIGINS=["http://localhost:3000"]
