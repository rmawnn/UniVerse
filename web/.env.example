# ── UniVerse Web — Environment Variables ──────────────────────
#
# Copy this file to .env.local and fill in values for your setup.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Backend API base URL (include /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket URL (optional — derived from API URL if not set).
# Set explicitly when the WS endpoint differs from the API host.
# Uses ws:// for local dev, wss:// for production.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
